# .replit configuration
language = "python3"

run = "pip install -r requirements.txt && python main.py"
modules = ["python-3.11"]

[packager]
language = "python3"

[packager.features]
packageSearch = true
guessImports = true

[languages.python3]
pattern = "**/*.py"

[languages.python3.languageServer]
type = "pyright"

[nix]

[agent]
expertMode = true

[[ports]]
localPort = 8080
externalPort = 80
